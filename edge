<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&family=JetBrains+Mono:wght@300;400;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0d1117;
  --surface:#121920;
  --surface2:#161f28;
  --border:#1c2a20;
  --border-green:rgba(74,222,128,0.13);
  --green:#4ade80;
  --red:#ff4d4d;
  --yellow:#f5c518;
  --blue:#3b9eff;
  --purple:#c084fc;
  --orange:#ff7c00;
  --text:#e8f0ea;
  --text-2:rgba(232,240,234,0.52);
  --text-3:rgba(232,240,234,0.24);
  --muted:#3a5a42;
  --accent:#4ade80;
}

* { margin:0; padding:0; box-sizing:border-box; }
html, body { background:var(--bg); color:var(--text); font-family:'DM Sans',sans-serif; min-height:100vh; overflow-x:hidden; }

/* ── NAV ── */
nav {
  position:sticky; top:0; z-index:100;
  background:rgba(13,17,23,0.94); backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
  padding:0 32px; display:flex; align-items:stretch; height:52px;
}
.nav-wordmark {
  font-family:'Bebas Neue',sans-serif; font-size:17px; letter-spacing:3px;
  display:flex; align-items:center; margin-right:28px; text-decoration:none; white-space:nowrap;
}
.nav-wordmark .w1 { color:var(--text); opacity:0.75; }
.nav-wordmark .w2 { color:var(--accent); }
.nav-links { display:flex; align-items:stretch; gap:2px; flex:1; }
.nav-link {
  font-family:'JetBrains Mono',monospace; font-size:9px; letter-spacing:2px;
  text-transform:uppercase; padding:0 16px; display:flex; align-items:center;
  color:var(--text-3); text-decoration:none; transition:color .15s; white-space:nowrap;
}
.nav-link:hover { color:var(--text-2); }
.nav-link.active { color:var(--accent); border-bottom:2px solid var(--accent); }
.nav-cta {
  margin-left:auto; font-family:'JetBrains Mono',monospace; font-size:9px; letter-spacing:2px;
  text-transform:uppercase; display:flex; align-items:center; padding:0 18px;
  background:rgba(74,222,128,0.08); border-left:1px solid var(--border-green);
  color:var(--accent); text-decoration:none; transition:background .15s; white-space:nowrap;
}
.nav-cta:hover { background:rgba(74,222,128,0.14); }

/* ── PAGE ── */
main { max-width:1080px; margin:0 auto; padding:32px 24px 80px; }

.page-eyebrow {
  font-family:'JetBrains Mono',monospace; font-size:9px; letter-spacing:3px;
  text-transform:uppercase; color:var(--accent); margin-bottom:10px;
  display:flex; align-items:center; gap:8px;
}
.live-pip { width:5px; height:5px; border-radius:50%; background:var(--accent); animation:blink 1.6s infinite; flex-shrink:0; }
@keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0.2;} }

.page-title {
  font-family:'Bebas Neue',sans-serif; font-size:clamp(36px,6vw,64px);
  letter-spacing:2px; line-height:0.95; color:var(--text); margin-bottom:6px;
}
.page-title span { color:var(--accent); }
.page-sub { font-size:14px; color:var(--text-2); font-weight:300; margin-bottom:36px; max-width:520px; line-height:1.7; }

/* ── SESSION CLOCK ── */
.session-bar {
  display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin-bottom:28px;
}
.session-card {
  background:var(--surface); border:1px solid var(--border);
  border-radius:12px; padding:16px 18px; position:relative; overflow:hidden;
  transition:border-color 0.2s;
}
.session-card.active {
  border-color:var(--border-green);
  background:linear-gradient(135deg, var(--surface) 60%, rgba(74,222,128,0.04));
}
.session-card.overlap {
  border-color:rgba(245,197,24,0.25);
  background:linear-gradient(135deg, var(--surface) 60%, rgba(245,197,24,0.04));
}
.session-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:2px; border-radius:12px 12px 0 0;
  background:var(--border);
}
.session-card.active::before { background:var(--accent); }
.session-card.overlap::before { background:var(--yellow); }
.session-card.closed::before { background:var(--border); }
.session-name {
  font-family:'JetBrains Mono',monospace; font-size:8px; letter-spacing:2px;
  text-transform:uppercase; color:var(--text-3); margin-bottom:8px;
}
.session-card.active .session-name { color:var(--accent); }
.session-card.overlap .session-name { color:var(--yellow); }
.session-status {
  font-family:'Bebas Neue',sans-serif; font-size:22px; letter-spacing:2px;
  line-height:1; margin-bottom:4px;
}
.session-card.active .session-status { color:var(--accent); }
.session-card.overlap .session-status { color:var(--yellow); }
.session-card.closed .session-status { color:var(--muted); }
.session-time {
  font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--text-3);
}
.session-countdown {
  font-family:'JetBrains Mono',monospace; font-size:9px; letter-spacing:1px;
  color:var(--text-3); margin-top:4px;
}
.session-card.active .session-countdown { color:rgba(74,222,128,0.6); }
.session-card.overlap .session-countdown { color:rgba(245,197,24,0.6); }

/* ── EDGE STATS GRID ── */
.edge-grid {
  display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin-bottom:28px;
}
.edge-card {
  background:var(--surface); border:1px solid var(--border);
  border-radius:12px; padding:20px 18px; transition:border-color 0.2s;
  position:relative; overflow:hidden;
}
.edge-card:hover { border-color:var(--border-green); }
.edge-card-label {
  font-family:'JetBrains Mono',monospace; font-size:8px; letter-spacing:2px;
  text-transform:uppercase; color:var(--text-3); margin-bottom:10px;
}
.edge-card-value {
  font-family:'Bebas Neue',sans-serif; font-size:28px; letter-spacing:1px;
  line-height:1; margin-bottom:4px;
}
.edge-card-value.pos   { color:var(--green); }
.edge-card-value.neg   { color:var(--red); }
.edge-card-value.neu   { color:var(--text); }
.edge-card-value.warn  { color:var(--yellow); }
.edge-card-sub {
  font-family:'JetBrains Mono',monospace; font-size:9px; color:var(--text-3);
  line-height:1.5;
}
.edge-card-tag {
  display:inline-block; font-family:'JetBrains Mono',monospace;
  font-size:8px; letter-spacing:1px; text-transform:uppercase;
  padding:2px 7px; border-radius:3px; margin-top:8px;
}
.edge-card-tag.pos { background:rgba(74,222,128,0.08); color:var(--green); border:1px solid rgba(74,222,128,0.2); }
.edge-card-tag.neg { background:rgba(255,77,77,0.08); color:var(--red); border:1px solid rgba(255,77,77,0.2); }
.edge-card-tag.neu { background:rgba(255,255,255,0.04); color:var(--text-2); border:1px solid var(--border); }
.edge-card-tag.warn { background:rgba(245,197,24,0.08); color:var(--yellow); border:1px solid rgba(245,197,24,0.2); }
.edge-card-source {
  font-family:'JetBrains Mono',monospace; font-size:8px; letter-spacing:1px;
  color:rgba(74,222,128,0.3); margin-top:8px;
}

/* ── BOTTOM ROW ── */
.bottom-row { display:grid; grid-template-columns:1fr 1fr; gap:10px; }

/* Liq feed */
.liq-feed-card {
  background:var(--surface); border:1px solid var(--border);
  border-radius:12px; overflow:hidden;
}
.card-header {
  display:flex; align-items:center; justify-content:space-between;
  padding:14px 18px; border-bottom:1px solid var(--border);
  background:var(--surface2);
}
.card-header-title {
  font-family:'JetBrains Mono',monospace; font-size:9px; letter-spacing:2px;
  text-transform:uppercase; color:var(--text-3);
}
.card-header-badge {
  display:flex; align-items:center; gap:6px;
  font-family:'JetBrains Mono',monospace; font-size:9px; letter-spacing:1.5px;
  text-transform:uppercase; color:var(--accent);
}
.feed-pip { width:5px; height:5px; border-radius:50%; background:var(--accent); animation:blink 1.5s infinite; }
.feed-list {
  height:280px; overflow-y:auto; padding:8px 0;
}
.feed-list::-webkit-scrollbar { width:2px; }
.feed-list::-webkit-scrollbar-track { background:var(--bg); }
.feed-list::-webkit-scrollbar-thumb { background:var(--border); }
.feed-item {
  display:flex; align-items:center; justify-content:space-between;
  padding:7px 18px; border-bottom:1px solid rgba(28,42,32,0.4);
  animation:feedin 0.3s ease;
}
.feed-item:last-child { border-bottom:none; }
@keyframes feedin { from{opacity:0; transform:translateY(-4px);} to{opacity:1; transform:translateY(0);} }
.feed-item-left { display:flex; flex-direction:column; gap:2px; }
.feed-side {
  font-family:'JetBrains Mono',monospace; font-size:8px; letter-spacing:1.5px;
  text-transform:uppercase; font-weight:600;
}
.feed-side.long  { color:var(--green); }
.feed-side.short { color:var(--red); }
.feed-price {
  font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--text);
}
.feed-item-right { display:flex; flex-direction:column; align-items:flex-end; gap:2px; }
.feed-size {
  font-family:'Bebas Neue',sans-serif; font-size:16px; letter-spacing:1px;
}
.feed-size.long  { color:var(--green); }
.feed-size.short { color:var(--red); }
.feed-size.large { color:var(--yellow); }
.feed-size.whale { color:var(--purple); }
.feed-time { font-family:'JetBrains Mono',monospace; font-size:8px; color:var(--text-3); }
.feed-empty {
  display:flex; align-items:center; justify-content:center; height:100%;
  font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:2px;
  text-transform:uppercase; color:var(--muted);
}

/* Market bias card */
.bias-card {
  background:var(--surface); border:1px solid var(--border);
  border-radius:12px; overflow:hidden;
}
.bias-body { padding:18px; }
.bias-section { margin-bottom:20px; }
.bias-section:last-child { margin-bottom:0; }
.bias-label {
  font-family:'JetBrains Mono',monospace; font-size:8px; letter-spacing:2px;
  text-transform:uppercase; color:var(--text-3); margin-bottom:8px;
}
.bias-row {
  display:flex; align-items:center; justify-content:space-between;
  margin-bottom:6px;
}
.bias-name {
  font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--text-2);
}
.bias-val {
  font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:600;
}
.bias-val.pos  { color:var(--green); }
.bias-val.neg  { color:var(--red); }
.bias-val.neu  { color:var(--text-2); }
.bias-val.warn { color:var(--yellow); }
.bias-bar-bg { height:3px; background:var(--border); border-radius:2px; overflow:hidden; margin-bottom:14px; }
.bias-bar-fill { height:100%; border-radius:2px; transition:width 0.5s ease; }
.bias-bar-fill.pos  { background:var(--green); }
.bias-bar-fill.neg  { background:var(--red); }
.bias-bar-fill.warn { background:var(--yellow); }

.overall-read {
  background:var(--surface2); border:1px solid var(--border);
  border-left:2px solid var(--accent); border-radius:6px;
  padding:12px 14px; margin:0 18px 18px;
  font-size:12px; line-height:1.75; color:var(--text-2); font-weight:300;
}
.overall-read strong { color:var(--accent); font-weight:500; }
.overall-read .warn  { color:var(--yellow); }
.overall-read .danger { color:var(--red); }

/* ── MOBILE ── */
@media(max-width:900px) {
  .session-bar { grid-template-columns:1fr 1fr; }
  .edge-grid { grid-template-columns:1fr 1fr; }
  .bottom-row { grid-template-columns:1fr; }
}
@media(max-width:600px) {
  nav { padding:0 16px; }
  .nav-link { display:none; }
  .nav-cta { font-size:8px; padding:0 14px; }
  main { padding:20px 16px 60px; }
  .session-bar { grid-template-columns:1fr 1fr; gap:8px; }
  .edge-grid { grid-template-columns:1fr 1fr; gap:8px; }
  .edge-card-value { font-size:22px; }
}
</style>
