<script>
const WORKER='https://cryptoquant-proxy.scottchristie049.workers.dev';
const ASSETS_CFG={BTC:{sym:'BTCUSDT',mmr:0.004}};
const TIERS=[{lev:100,r:255,g:77,b:77},{lev:50,r:245,g:197,b:24},{lev:25,r:59,g:158,b:255}];

let btcPrice=null, buyWalls=[], sellWalls=[], liqLevels=[];
let fundingRate=null, oiCurrent=null, oiPrev=null, takerRatio=null;

async function cqFetch(ep,params){
  const p=new URLSearchParams({endpoint:ep,...params});
  const r=await fetch(WORKER+'?'+p.toString());
  return r.json();
}
async function binFetch(url){
  const r=await fetch(WORKER+'?url='+encodeURIComponent(url));
  return r.json();
}

const fmt=p=>p==null?'--':'$'+Math.round(p).toLocaleString('en-US');
const fmtUsd=v=>v>=1e9?'$'+(v/1e9).toFixed(2)+'B':v>=1e6?'$'+(v/1e6).toFixed(1)+'M':v>=1e3?'$'+(v/1e3).toFixed(0)+'K':'$'+v.toFixed(0);
const fmtPct=v=>(v>=0?'+':'')+v.toFixed(4)+'%';

// ── SESSION CLOCK ──
const SESSIONS={
  asia:   {start:0,  end:9,  el:'sess-asia',   type:'normal'},
  london: {start:8,  end:17, el:'sess-london',  type:'normal'},
  overlap:{start:13, end:17, el:'sess-overlap', type:'overlap'},
  ny:     {start:13, end:22, el:'sess-ny',      type:'normal'},
};

function updateSessions(){
  const now=new Date();
  const utcH=now.getUTCHours();
  const utcM=now.getUTCMinutes();
  const utcS=now.getUTCSeconds();
  const utcMins=utcH*60+utcM;

  Object.entries(SESSIONS).forEach(([key,s])=>{
    const card=document.getElementById(s.el);
    const statusEl=document.getElementById(s.el+'-status');
    const cdEl=document.getElementById(s.el+'-cd');
    const startMins=s.start*60, endMins=s.end*60;
    const isOpen=utcMins>=startMins&&utcMins<endMins;

    card.className='session-card '+(isOpen?(s.type==='overlap'?'overlap':'active'):'closed');
    statusEl.textContent=isOpen?'OPEN':'CLOSED';

    if(isOpen){
      const minsLeft=endMins-utcMins;
      const h=Math.floor(minsLeft/60), m=minsLeft%60;
      cdEl.textContent='Closes in '+h+'h '+m+'m';
    } else {
      // next open
      let minsUntil=startMins-utcMins;
      if(minsUntil<0)minsUntil+=1440;
      const h=Math.floor(minsUntil/60), m=minsUntil%60;
      cdEl.textContent='Opens in '+h+'h '+m+'m';
    }
  });
}
updateSessions();
setInterval(updateSessions,30000);

// ── PRICE WEBSOCKET ──
function startPriceFeed(){
  const ws=new WebSocket('wss://fstream.binance.com/ws/btcusdt@ticker');
  ws.onmessage=e=>{
    const d=JSON.parse(e.data);
    btcPrice=parseFloat(d.c);
  };
  ws.onclose=()=>setTimeout(startPriceFeed,3000);
}
startPriceFeed();

// ── LIVE LIQ FEED ──
const MAX_FEED=60;
let feedItems=[];

function startLiqFeed(){
  const ws=new WebSocket('wss://fstream.binance.com/ws/btcusdt@forceOrder');
  ws.onmessage=e=>{
    const o=JSON.parse(e.data).o;
    if(!o)return;
    const side=o.S==='BUY'?'short':'long'; // BUY order = short position liquidated
    const price=parseFloat(o.p);
    const qty=parseFloat(o.q);
    const usd=price*qty;
    if(usd<10000)return; // filter dust
    const now=new Date();
    const timeStr=now.toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
    feedItems.unshift({side,price,usd,time:timeStr});
    if(feedItems.length>MAX_FEED)feedItems=feedItems.slice(0,MAX_FEED);
    renderFeed();
  };
  ws.onclose=()=>setTimeout(startLiqFeed,3000);
}

function sizeClass(usd){
  if(usd>=1000000)return'whale';
  if(usd>=100000)return'large';
  return''; // normal — use side colour
}

function renderFeed(){
  const list=document.getElementById('feedList');
  if(!feedItems.length){
    list.innerHTML='<div class="feed-empty">Waiting for liquidations...</div>';
    return;
  }
  list.innerHTML=feedItems.map((f,i)=>{
    const sc=sizeClass(f.usd);
    const sizeColClass=sc||f.side;
    const label=f.side==='long'?'▼ LONG LIQ':'▲ SHORT LIQ';
    const whale=f.usd>=1000000?'🐋 ':f.usd>=100000?'⚡ ':'';
    return`<div class="feed-item" style="${i===0?'':''}">
      <div class="feed-item-left">
        <span class="feed-side ${f.side}">${label}</span>
        <span class="feed-price">${fmt(f.price)}</span>
      </div>
      <div class="feed-item-right">
        <span class="feed-size ${sizeColClass}">${whale}${fmtUsd(f.usd)}</span>
        <span class="feed-time">${f.time}</span>
      </div>
    </div>`;
  }).join('');
}
startLiqFeed();

// ── DEPTH → WALLS ──
async function fetchDepth(){
  try{
    const data=await binFetch('https://fapi.binance.com/fapi/v1/depth?symbol=BTCUSDT&limit=1000');
    if(!btcPrice)return;
    const price=btcPrice;
    const rangeLow=price*0.97, rangeHigh=price*1.03;
    const bucket=price*0.001;
    const bidB={},askB={};
    for(const[p,q]of data.bids){const fp=+p,fq=+q;if(fp<rangeLow)continue;const b=Math.floor(fp/bucket)*bucket;bidB[b]=(bidB[b]||0)+fp*fq;}
    for(const[p,q]of data.asks){const fp=+p,fq=+q;if(fp>rangeHigh)continue;const b=Math.floor(fp/bucket)*bucket;askB[b]=(askB[b]||0)+fp*fq;}
    buyWalls=Object.entries(bidB).map(([p,usd])=>({price:+p,usd})).filter(w=>w.usd>=200000).sort((a,b)=>b.usd-a.usd);
    sellWalls=Object.entries(askB).map(([p,usd])=>({price:+p,usd})).filter(w=>w.usd>=200000).sort((a,b)=>b.usd-a.usd);
    buildLiqLevels(data);
    updateEdgeCards();
  }catch(e){console.error('Depth:',e);}
  setTimeout(fetchDepth,30000);
}

// ── LIQ MODEL ──
function buildLiqLevels(depth){
  if(!btcPrice)return;
  const p=btcPrice, mmr=0.004, bucketSz=p*0.001;
  const posMap={};
  const addPos=(px,qty)=>{
    const ep=parseFloat(px),val=parseFloat(qty)*ep;
    if(val<1000)return;
    const b=Math.round(ep/bucketSz)*bucketSz;
    posMap[b]=(posMap[b]||0)+val;
  };
  if(depth.bids)depth.bids.forEach(([p,q])=>addPos(p,q));
  if(depth.asks)depth.asks.forEach(([p,q])=>addPos(p,q));
  const liqMap={};
  Object.entries(posMap).forEach(([eStr,size])=>{
    const entry=parseFloat(eStr);
    TIERS.forEach(({lev,r,g,b})=>{
      const longLiq=entry*(1-1/lev+mmr);
      const shortLiq=entry*(1+1/lev-mmr);
      if(longLiq>p*0.94&&longLiq<p*0.9999){
        const lb=Math.round(longLiq/bucketSz)*bucketSz;
        if(!liqMap[lb])liqMap[lb]={price:lb,size:0,side:'long',lev};
        liqMap[lb].size+=size*(1/lev);
      }
      if(shortLiq<p*1.06&&shortLiq>p*1.0001){
        const sb=Math.round(shortLiq/bucketSz)*bucketSz;
        if(!liqMap[sb])liqMap[sb]={price:shortLiq,size:0,side:'short',lev};
        liqMap[sb].size+=size*(1/lev);
      }
    });
  });
  liqLevels=Object.values(liqMap).sort((a,b)=>a.price-b.price);
}

// ── CQ DATA ──
async function fetchCQData(){
  try{
    const[fr,oi1,oi2,taker]=await Promise.all([
      cqFetch('btc/market-data/funding-rates',{window:'hour',limit:1,exchange:'all_exchange'}),
      cqFetch('btc/market-data/open-interest',{window:'hour',limit:1,exchange:'all_exchange'}),
      cqFetch('btc/market-data/open-interest',{window:'hour',limit:2,exchange:'all_exchange'}),
      cqFetch('btc/market-data/taker-buy-sell-stats',{window:'hour',limit:1,exchange:'all_exchange'}),
    ]);
    fundingRate=(fr?.result?.data?.[0]?.funding_rates??0)/100;
    oiCurrent=oi1?.result?.data?.[0]?.open_interest??null;
    oiPrev=oi2?.result?.data?.[0]?.open_interest??null;
    takerRatio=taker?.result?.data?.[0]?.taker_buy_ratio??null;
    updateEdgeCards();
    updateBiasRead();
  }catch(e){console.error('CQ:',e);}
  setTimeout(fetchCQData,60000);
}

// ── EDGE CARDS ──
function updateEdgeCards(){
  const p=btcPrice;

  // Funding
  if(fundingRate!==null){
    const fr=fundingRate;
    const frPct=(fr*100).toFixed(4)+'%';
    const cls=fr>0.0001?'pos':fr<-0.0001?'neg':'neu';
    const tagTxt=fr>0.0001?'Longs paying — bullish lean':fr<-0.0001?'Shorts paying — bearish lean':'Neutral';
    const tagCls=fr>0.0001?'pos':fr<-0.0001?'neg':'neu';
    setCard('e-funding',(fr>=0?'+':'')+frPct,cls,'8hr funding rate',tagTxt,tagCls);
  }

  // OI
  if(oiCurrent!==null&&oiPrev!==null){
    const delta=oiPrev>0?((oiCurrent-oiPrev)/oiPrev*100):0;
    const cls=delta>0.5?'pos':delta<-0.5?'neg':'neu';
    const sub=oiCurrent>=1e9?'$'+(oiCurrent/1e9).toFixed(2)+'B total OI':'$'+(oiCurrent/1e6).toFixed(0)+'M total OI';
    const tagTxt=delta>0.5?'Leverage building':delta<-0.5?'Positions closing':'Stable OI';
    const tagCls=delta>0.5?'warn':delta<-0.5?'neg':'neu';
    setCard('e-oi',(delta>=0?'+':'')+delta.toFixed(2)+'%',cls,sub,tagTxt,tagCls);
  }

  // Nearest wall
  if(p&&(buyWalls.length||sellWalls.length)){
    const nearBuy=buyWalls[0];
    const nearSell=sellWalls[0];
    let wallPrice=null, wallSide='', wallUsd=0;
    if(nearBuy&&nearSell){
      const buyDist=Math.abs(nearBuy.price-p);
      const sellDist=Math.abs(nearSell.price-p);
      if(buyDist<sellDist){wallPrice=nearBuy.price;wallSide='buy';wallUsd=nearBuy.usd;}
      else{wallPrice=nearSell.price;wallSide='sell';wallUsd=nearSell.usd;}
    } else if(nearBuy){wallPrice=nearBuy.price;wallSide='buy';wallUsd=nearBuy.usd;}
    else{wallPrice=nearSell.price;wallSide='sell';wallUsd=nearSell.usd;}
    const dist=((wallPrice-p)/p*100).toFixed(2);
    const cls=wallSide==='buy'?'pos':'neg';
    const tagTxt=wallSide==='buy'?'▲ Buy wall below':'▼ Sell wall above';
    setCard('e-wall',fmt(wallPrice),cls,(dist>=0?'+':'')+dist+'% away · '+fmtUsd(wallUsd),tagTxt,cls);
  }

  // Nearest liq cluster
  if(p&&liqLevels.length){
    const sorted=[...liqLevels].sort((a,b)=>Math.abs(a.price-p)-Math.abs(b.price-p));
    const nearest=sorted[0];
    if(nearest){
      const dist=((nearest.price-p)/p*100).toFixed(2);
      const cls=nearest.side==='long'?'neg':'pos';
      const tagTxt=nearest.lev+'x '+nearest.side+' liq';
      const tagCls=nearest.side==='long'?'neg':'pos';
      setCard('e-liq',fmt(nearest.price),cls,(dist>=0?'+':'')+dist+'% · '+fmtUsd(nearest.size)+' at risk',tagTxt,tagCls);
    }
  }
}

function setCard(id,value,valueCls,sub,tagTxt,tagCls){
  const card=document.getElementById(id);
  if(!card)return;
  const valEl=card.querySelector('.edge-card-value');
  const subEl=card.querySelector('.edge-card-sub');
  const tagEl=card.querySelector('.edge-card-tag');
  if(valEl){valEl.textContent=value;valEl.className='edge-card-value '+valueCls;}
  if(subEl)subEl.textContent=sub;
  if(tagEl){tagEl.textContent=tagTxt;tagEl.className='edge-card-tag '+tagCls;}
}

// ── BIAS READ ──
function updateBiasRead(){
  const signals=[];

  // Funding
  if(fundingRate!==null){
    const fr=fundingRate;
    const cls=fr>0.0001?'pos':fr<-0.0001?'neg':'neu';
    const barW=Math.min(100,50+Math.abs(fr)/0.001*20);
    const barDir=fr>0?'pos':fr<0?'neg':'neu';
    document.getElementById('b-fund-val').textContent=(fr>=0?'+':''+(fr*100).toFixed(4))+'%';
    document.getElementById('b-fund-val').className='bias-val '+cls;
    document.getElementById('b-fund-bar').style.width=barW+'%';
    document.getElementById('b-fund-bar').className='bias-bar-fill '+barDir;
    if(fr>0.0002)signals.push({txt:'funding strongly positive — longs overextended',type:'warn'});
    else if(fr>0.00005)signals.push({txt:'funding slightly positive — mild long bias',type:'pos'});
    else if(fr<-0.00005)signals.push({txt:'funding negative — shorts paying, potential squeeze',type:'pos'});
  }

  // OI
  if(oiCurrent!==null&&oiPrev!==null){
    const delta=oiPrev>0?((oiCurrent-oiPrev)/oiPrev*100):0;
    const cls=delta>0.5?'pos':delta<-0.5?'neg':'neu';
    const barW=Math.min(100,50+Math.abs(delta)*10);
    document.getElementById('b-oi-val').textContent=(delta>=0?'+':'')+delta.toFixed(2)+'%';
    document.getElementById('b-oi-val').className='bias-val '+cls;
    document.getElementById('b-oi-bar').style.width=barW+'%';
    document.getElementById('b-oi-bar').className='bias-bar-fill '+(delta>0?'pos':'neg');
    if(delta>1)signals.push({txt:'OI rising — new money entering, leverage building',type:'warn'});
    else if(delta<-1)signals.push({txt:'OI falling — positions closing, reduced conviction',type:'neg'});
  }

  // Taker
  if(takerRatio!==null){
    const r=takerRatio;
    const pct=(r*100).toFixed(1);
    const cls=r>0.55?'pos':r<0.45?'neg':'neu';
    const barW=(r*100);
    document.getElementById('b-taker-val').textContent=pct+'% buy';
    document.getElementById('b-taker-val').className='bias-val '+cls;
    document.getElementById('b-taker-bar').style.width=barW+'%';
    document.getElementById('b-taker-bar').className='bias-bar-fill '+(r>0.5?'pos':'neg');
    if(r>0.6)signals.push({txt:'buyers aggressively initiating — strong upside pressure',type:'pos'});
    else if(r>0.52)signals.push({txt:'mild buy aggression — slight upside lean',type:'pos'});
    else if(r<0.4)signals.push({txt:'sellers initiating heavily — downside pressure',type:'neg'});
    else if(r<0.48)signals.push({txt:'mild sell aggression — slight downside lean',type:'neg'});
  }

  // Overall read
  const readEl=document.getElementById('overallRead');
  if(signals.length){
    const txt=signals.map(s=>`<span class="${s.type}">${s.txt}</span>`).join('<br>');
    readEl.innerHTML=txt;
  } else {
    readEl.innerHTML='<strong>Mixed signals.</strong> No strong directional bias right now. Wait for a cleaner setup.';
  }

  document.getElementById('bias-updated').textContent=new Date().toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit',timeZone:'Asia/Dubai'})+' GST';
}

// ── INIT ──
// Wait for price before depth/liq
function waitAndFetch(){
  if(btcPrice){fetchDepth();fetchCQData();}
  else setTimeout(waitAndFetch,300);
}
setTimeout(waitAndFetch,500);
